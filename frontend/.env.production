# Production Environment Variables Template
# These will be replaced by Railway's environment variables during build

# Backend API URL
VITE_API_URL=https://backend-production-85fd.up.railway.app/api/v1

# Supabase Configuration
VITE_SUPABASE_URL=$VITE_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY

# Facebook API Configuration
VITE_FACEBOOK_ACCESS_TOKEN=$VITE_FACEBOOK_ACCESS_TOKEN
VITE_FACEBOOK_AD_ACCOUNT_ID=$VITE_FACEBOOK_AD_ACCOUNT_ID
